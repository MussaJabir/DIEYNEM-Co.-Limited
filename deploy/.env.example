# DIEYNEM production environment — copy to the project root as `.env` on the
# server (NOT committed). django-environ reads it at startup.
#   cp deploy/.env.example .env   &&   edit the values   &&   chmod 640 .env
#
# Owner/group must let Gunicorn (www-data) read it:
#   sudo chown ubuntu:www-data .env && chmod 640 .env

# Django picks settings from this in the systemd unit, but set it here too for
# manage.py one-offs run by hand.
DJANGO_SETTINGS_MODULE=config.settings.prod

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_50_char_random_string
DJANGO_ALLOWED_HOSTS=dieynem.bjptechnologies.co.tz

# PostgreSQL (installed alongside the existing MySQL — different port 5432).
# Create the role/db per deploy/README.md, then put the password here.
DATABASE_URL=postgres://dieynem:CHANGE_ME_db_password@127.0.0.1:5432/dieynem

# Behind Apache TLS: Django learns the request was HTTPS from X-Forwarded-Proto
# (set by the vhost). Keep the redirect on.
DJANGO_SECURE_SSL_REDIRECT=True

# Per-process in-memory cache (no extra service; fine for this low-traffic site).
DJANGO_CACHE_URL=locmemcache://dieynem-cache

# Swahili toggle stays hidden until the translations are filled in.
DJANGO_SHOW_LANGUAGE_TOGGLE=False

# Email — lead notifications to info@dieynem.co.tz. Fill with the real SMTP.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=info@dieynem.co.tz
LEADS_NOTIFY_EMAIL=info@dieynem.co.tz
