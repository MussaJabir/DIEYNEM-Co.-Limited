# Copy to .env for local development. Never commit your real .env.

# --- Django core ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Dev defaults to SQLite if DATABASE_URL is unset.
# Production (PostgreSQL):
# DATABASE_URL=postgres://user:password@localhost:5432/dieynem

# --- Email (lead notifications; prod uses SMTP, dev prints to console) ---
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=info@dieynem.co.tz
LEADS_NOTIFY_EMAIL=info@dieynem.co.tz

# --- Security (production) ---
# DJANGO_SECURE_SSL_REDIRECT=True
